# Neon PostgreSQL Database Connection
# Get this from your Neon console: https://console.neon.tech/app/projects/long-hill-90158403/branches/br-lingering-cell-ai19xt06/tables
# Click "Connect" → "Database" to get your connection string

DATABASE_URL=postgresql://[username]:[password]@ep-[endpoint].us-east-1.aws.neon.tech/[database]?sslmode=require

# Example format (replace with your actual credentials):
# DATABASE_URL=postgresql://myuser:mypassword@ep-cool-river-123456.us-east-1.aws.neon.tech/mydb?sslmode=require

# Optional: Database connection settings
DB_MAX_CONNECTIONS=10
DB_CONNECTION_TIMEOUT=30000
DB_IDLE_TIMEOUT=30000
DB_ENABLE_KEEPALIVE=true

# Application settings
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
