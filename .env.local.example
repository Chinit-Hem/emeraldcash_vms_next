# =============================================================================
# Cloudinary Configuration for Image Uploads
# =============================================================================
# These variables are REQUIRED for vehicle image uploads to work.
# Copy this file to .env.local and fill in your actual values.
# Get your credentials from: https://cloudinary.com/console
# =============================================================================

# Your Cloudinary cloud name (found in your Cloudinary dashboard)
# Example: If your cloud URL is https://res.cloudinary.com/mycompany/,
# then your cloud name is "mycompany"
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name_here

# Unsigned upload preset name (create this in Cloudinary dashboard)
# This allows direct uploads from the browser without authentication
# See CLOUDINARY_SETUP_GUIDE.md for instructions on creating this
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=your_unsigned_preset_name

# =============================================================================
# Optional: Cloudinary Folder Organization
# =============================================================================
# Vehicles will be uploaded to folders based on category (Cars, Motorcycles, etc.)
# The folder structure is: {category}/vehicle_{id}_{timestamp}

# =============================================================================
# Other Environment Variables (if needed)
# =============================================================================
# Add your other environment variables below...
